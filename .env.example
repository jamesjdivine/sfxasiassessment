# Copy to .env.local for local dev. Never commit real values.

# Anthropic (Claude) — required for the conversational layer
ANTHROPIC_API_KEY=sk-ant-...

# Netlify DB / Neon Postgres — auto-injected on Netlify; for local dev, paste the
# connection string from the Netlify UI (Site configuration → Environment variables)
NETLIFY_DATABASE_URL=postgres://...

# Resend transactional email
RESEND_API_KEY=re_...

# SnowFox routing
SNOWFOX_LEADS_EMAIL=info@snowfoxsolutions.com
SNOWFOX_FROM_EMAIL=assessments@snowfoxsolutions.com

# Canonical app URL (used to build links inside emails)
PUBLIC_APP_URL=http://localhost:3000
